# --- Демо-чатбот QADAM для сайта. Скопируй в .env и заполни. ---
# .env НЕ коммитить (см. .gitignore).

# OpenAI — нужен для RAG-ответов на редкие вопросы (миссия, KPI, устав и т.п.).
# Без ключа бот всё равно работает: базовые вопросы (цена/расписание/пробное) отвечаются
# локально без OpenAI, а на остальное честно предлагает уточнить у менеджера.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# RAG
RAG_K=4
RAG_MIN_SCORE=0.20
# В демо индекс уже собран (data/qadam_rag_index.json). Если правишь qadam_knowledge.txt —
# пересобери: python rag_index.py  (или оставь AUTO=yes, чтобы собрался при первом запросе).
RAG_AUTO_BUILD_INDEX=no
RAG_MAX_ANSWER_CHARS=900
RAG_MAX_QUESTION_CHARS=1000
# Бэкстоп против разорения бюджета OpenAI: максимум RAG-ответов в сутки (<=0 — без лимита).
OPENAI_DAILY_CAP=2000

# Веб-адаптер (web_connector.py) — публичный вход, который зовёт ваш сайт.
# Адрес приватного Rasa REST (наружу не выставляется):
RASA_REST_URL=http://127.0.0.1:5005/webhooks/rest/webhook
# Разрешённые origin'ы сайта через запятую. Для демо "*"; в проде укажи домен, напр.:
# WEB_CONNECTOR_CORS_ORIGINS=https://qadam.kz
WEB_CONNECTOR_CORS_ORIGINS=*

# Общие лимиты/стейт
MAX_MESSAGE_LEN=1000
BOT_STATE_DB=data/bot_state.db
SEEN_TTL_SECONDS=86400
